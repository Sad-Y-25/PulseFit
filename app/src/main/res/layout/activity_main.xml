<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_navy">

    <!-- 1. L'image de fond dynamique identique à l'authentification -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_auth"
        android:scaleType="centerCrop" />

    <!-- 2. Filtre sombre pour garantir le contraste et l'effet Glassmorphism -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" /> <!-- Opacité à 70% pour bien lire les stats -->

    <!-- 3. Contenu défilant -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="60dp"
            android:paddingBottom="40dp"
            android:paddingHorizontal="24dp">

            <!-- En-tête du Dashboard -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TABLEAU DE BORD"
                        android:textColor="#B3FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prêt à transpirer ?"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.02"/>
                </LinearLayout>

                <!-- Bouton Déconnexion (Nouveau Style Glassmorphism Premium) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#40000000"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="#40FFFFFF">

                    <ImageView
                        android:id="@+id/btnLogout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_lock_power_off"
                        app:tint="@color/vert_neon"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Carte Résumé avec le même effet "Verre" que le Login -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#40000000"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#40FFFFFF"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="32dp">

                    <!-- Stat 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="@color/vert_neon"
                            android:textSize="36sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Séances"
                            android:textColor="#B3FFFFFF"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Ligne de séparation affinée -->
                    <View
                        android:layout_width="1.5dp"
                        android:layout_height="match_parent"
                        android:background="#40FFFFFF"
                        android:layout_marginHorizontal="16dp"/>

                    <!-- Stat 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.5h"
                            android:textColor="@color/bleu_electrique"
                            android:textSize="36sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temps total"
                            android:textColor="#B3FFFFFF"
                            android:fontFamily="sans-serif-medium"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Titre Section Menu -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIONS RAPIDES"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp"/>

            <!-- Bouton Menu 1 : Mes Entraînements (Refonte visuelle) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkouts"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="MES ENTRAÎNEMENTS"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                app:backgroundTint="#40000000"
                app:cornerRadius="24dp"
                app:strokeColor="@color/vert_neon"
                app:strokeWidth="1.5dp"
                android:layout_marginBottom="16dp"/>

            <!-- Bouton Menu 2 : Mon Profil (Refonte visuelle) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfile"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:text="MON PROFIL"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                app:backgroundTint="#40000000"
                app:cornerRadius="24dp"
                app:strokeColor="@color/bleu_electrique"
                app:strokeWidth="1.5dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>