<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_navy">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_auth"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000" /> <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TABLEAU DE BORD"
                    android:textColor="#B3FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prêt à transpirer ?"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.02"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardBackgroundColor="#40000000"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#40FFFFFF">

                <ImageView
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="@color/vert_neon"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#40000000"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="#40FFFFFF"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvTotalSessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/vert_neon"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Séances réservées"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="12sp"/>
                </LinearLayout>

                <View
                    android:layout_width="1.5dp"
                    android:layout_height="match_parent"
                    android:background="#40FFFFFF"
                    android:layout_marginHorizontal="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvTotalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0h"
                        android:textColor="@color/bleu_electrique"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Temps total"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="sans-serif-medium"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mot du Coach IA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#20FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/vert_neon"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_info"
                        app:tint="@color/vert_neon"
                        android:layout_marginEnd="8dp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOT DU COACH IA"
                        android:textColor="@color/vert_neon"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1"/>
                </LinearLayout>
                
                <TextView
                    android:id="@+id/tvAiQuote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&quot;Le succès commence par la discipline. Chaque séance vous rapproche de votre objectif.&quot;"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="italic"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIONS RAPIDES"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWorkouts"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="64dp"
                android:text="RÉSERVER"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconTint="@color/white"
                app:backgroundTint="#40000000"
                app:strokeColor="@color/bleu_electrique"
                app:strokeWidth="1.5dp"
                app:cornerRadius="16dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="64dp"
                android:text="PROFIL"
                android:textColor="@color/black"
                android:textSize="14sp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconTint="@color/black"
                app:backgroundTint="@color/vert_neon"
                app:cornerRadius="16dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="CLASSEMENT (GAMIFICATION)"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:icon="@android:drawable/btn_star_big_on"
            app:iconTint="#FFD700"
            app:backgroundTint="#40000000"
            app:strokeColor="#FFD700"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLocation"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="TROUVER LE CLUB"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:icon="@android:drawable/ic_dialog_map"
            app:iconTint="@color/white"
            app:backgroundTint="#40000000"
            app:strokeColor="@color/bleu_electrique"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"/>
    </LinearLayout>
    </ScrollView>

</RelativeLayout>